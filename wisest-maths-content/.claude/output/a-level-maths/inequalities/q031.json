      },
      {
        "stepNumber": 6,
        "description": "State the answer.",
        "workingLatex": "x > 9",
        "explanation": "The solution to the inequality is $x > 9$.",
        "diagram": null
      }
    ],
    "finalAnswer": "$\\dfrac{x}{3} - 2 > 1 \\Rightarrow \\dfrac{x}{3} > 3 \\Rightarrow x > 9$"
