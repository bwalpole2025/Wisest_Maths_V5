        "diagram": null
      },
      {
        "stepNumber": 5,
        "description": "Check the boundary is excluded.",
        "workingLatex": "x = 9: \\ \\tfrac{9}{3} - 2 = 1 \\not> 1",
        "explanation": "At $x = 9$ the expression equals $1$, which is not greater than $1$, so the boundary is correctly excluded.",
