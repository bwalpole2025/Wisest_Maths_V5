{
  "id": "al.y2.pure.rsin-form.q040",
  "level": "A-Level Maths",
  "topic": "Year 2 Pure",
  "subtopic": "The form Rsin(θ + α)",
  "subtopicId": "al.y2.pure.rsin-form",
