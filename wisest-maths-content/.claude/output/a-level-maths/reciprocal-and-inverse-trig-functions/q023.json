{
  "id": "al.y2.pure.reciprocal-inverse-trig.q023",
  "level": "A-Level Maths",
  "topic": "Year 2 Pure",
  "subtopic": "Reciprocal and inverse trig functions",
  "subtopicId": "al.y2.pure.reciprocal-inverse-trig",
  "difficulty": "Intermediate",
