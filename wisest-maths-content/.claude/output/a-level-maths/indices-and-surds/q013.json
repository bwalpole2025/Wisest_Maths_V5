{
  "id": "al.y1.pure.indices-surds.q013",
  "level": "A-Level Maths",
  "topic": "Year 1 Pure",
  "subtopic": "Indices and surds",
  "subtopicId": "al.y1.pure.indices-surds",
  "difficulty": "Intermediate",
