{
  "id": "al.y1.pure.quadratics.q046",
  "level": "A-Level Maths",
  "topic": "Year 1 Pure",
  "subtopic": "Quadratic functions",
  "subtopicId": "al.y1.pure.quadratics",
  "difficulty": "Hard",
