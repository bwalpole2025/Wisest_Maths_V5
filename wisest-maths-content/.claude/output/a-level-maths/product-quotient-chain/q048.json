{
  "id": "al.y2.pure.product-quotient-chain.q048",
  "level": "A-Level Maths",
  "topic": "Year 2 Pure",
  "subtopic": "Product, quotient and chain rules",
  "subtopicId": "al.y2.pure.product-quotient-chain",
  "difficulty": "Intermediate",
