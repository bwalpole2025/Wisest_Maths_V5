{
  "id": "al.y1.pure.proof-deduction.q070",
  "level": "A-Level Maths",
  "topic": "Year 1 Pure",
  "subtopic": "Proof by deduction and exhaustion",
  "subtopicId": "al.y1.pure.proof-deduction",
  "difficulty": "Hard",
