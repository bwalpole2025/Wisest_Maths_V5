{
  "id": "al.y2.pure.compound-double-angles.q027",
  "level": "A-Level Maths",
  "topic": "Year 2 Pure",
  "subtopic": "Compound and double angles",
  "subtopicId": "al.y2.pure.compound-double-angles",
  "difficulty": "Intermediate",
